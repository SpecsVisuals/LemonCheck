# .env.example
#
# LemonCheck — Required Environment Variables
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It is listed in .gitignore.
#
# Local dev:     .env in the project root, loaded by uvicorn via python-dotenv
# Railway:       Set these in the Railway dashboard → Variables tab
# Vercel:        Frontend-prefixed VITE_* vars go in Vercel dashboard → Settings → Env Vars


# ── AI Engine ────────────────────────────────────────────────────────────────
# Anthropic API key — used by claude_agent.py to call Claude Sonnet 4
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=


# ── Database & Auth (Supabase) ────────────────────────────────────────────────
# Your Supabase project URL
# Get from: Supabase dashboard → Settings → API → Project URL
SUPABASE_URL=

# Supabase anon (public) key — safe for frontend use
# Get from: Supabase dashboard → Settings → API → anon / public
SUPABASE_ANON_KEY=

# Supabase service role key — used ONLY by the backend for admin DB operations
# Get from: Supabase dashboard → Settings → API → service_role (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=


# ── Search APIs (for search_comps MCP tool) ───────────────────────────────────
# SerpAPI key — used to search comparable listings (primary)
# Get from: https://serpapi.com/dashboard
SERPAPI_KEY=

# Brave Search API key — fallback if SerpAPI is unavailable
# Get from: https://api.search.brave.com/
BRAVE_SEARCH_KEY=


# ── Demo & Caching ────────────────────────────────────────────────────────────
# Secret key used to sign/verify the demo cache — prevents tampering with demo_cache.json
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
DEMO_CACHE_SECRET=


# ── Deployment ────────────────────────────────────────────────────────────────
# The full URL of the deployed frontend (used for CORS allowlist in FastAPI)
# Local dev: http://localhost:5173
# Production: https://lemoncheck.vercel.app (update after first Vercel deploy)
FRONTEND_URL=http://localhost:5173


# ── Frontend-only variables (Vite — must be prefixed VITE_) ──────────────────
# These are also set in frontend/.env.local (not this file — see frontend/.env.local.example)
# Listed here for cross-reference so nothing gets missed during deployment.
#
# VITE_SUPABASE_URL=        (same value as SUPABASE_URL above)
# VITE_SUPABASE_ANON_KEY=   (same value as SUPABASE_ANON_KEY above)
# VITE_API_URL=             (Railway backend URL in production, http://localhost:8000 locally)
